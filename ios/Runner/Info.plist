<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Bundle Information -->
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>EcashBook</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>ecashbook_app</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- UI Configuration -->
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- BIOMETRIC PERMISSIONS -->
	<key>NSFaceIDUsageDescription</key>
	<string>EcashBook uses Face ID or Touch ID for secure authentication to protect your account and sensitive financial data. This ensures only you can access your payslips, attendance, and personal information.</string>

	<!-- CAMERA PERMISSIONS -->
	<key>NSCameraUsageDescription</key>
	<string>EcashBook needs camera access for Face ID authentication and secure face recognition login. This provides an additional layer of security for your account.</string>

	<!-- LOCATION PERMISSIONS -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>EcashBook needs location access to verify your work location for accurate attendance tracking and security purposes. This helps ensure you're checking in from authorized locations.</string>

	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>EcashBook needs location access to verify your work location for attendance tracking, security purposes, and to provide location-based features when the app is in use.</string>

	<key>NSLocationAlwaysUsageDescription</key>
	<string>EcashBook needs location access to verify your work location for attendance tracking and security purposes, even when the app is not actively in use.</string>

	<!-- Flutter Configuration -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- Background Modes (if needed for location) -->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
	</array>
</dict>
</plist>
